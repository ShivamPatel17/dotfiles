<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.shivam.sketchybar-restart-on-wake</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-l</string>
        <string>-c</string>
        <string>$HOME/.config/sketchybar/plugins/restart_on_wake.sh</string>
    </array>
    <key>LaunchEvents</key>
    <dict>
        <key>com.apple.notifyd.matching</key>
        <dict>
            <key>com.apple.sleep.wake</key>
            <dict>
                <key>Notification</key>
                <string>com.apple.powermanagement.systempowerstate</string>
            </dict>
        </dict>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/sketchybar-restart-on-wake.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/sketchybar-restart-on-wake.log</string>
</dict>
</plist>
